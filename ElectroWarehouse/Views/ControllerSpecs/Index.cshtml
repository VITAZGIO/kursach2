@model IEnumerable<ElectroWarehouse.Models.ControllerSpec>

@{
    ViewData["Title"] = "Спецификации контроллеров";
}

<h1>Спецификации контроллеров</h1>

<form asp-action="Index" method="get" class="row mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control"
               placeholder="Поиск по контроллеру, детали" />
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-primary">Найти</button>
        <a asp-action="Index" class="btn btn-secondary">Сбросить</a>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить спецификацию</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Контроллер</th>
            <th>Электродеталь</th>
            <th>Количество деталей на изделие</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@Html.DisplayFor(modelItem => item.ControllerDevice.Name)</td>
            <td>@Html.DisplayFor(modelItem => item.Part.Name)</td>
            <td>@Html.DisplayFor(modelItem => item.QuantityPerUnit)</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Изменить</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Подробнее</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
            </td>
        </tr>
}
    </tbody>
</table>