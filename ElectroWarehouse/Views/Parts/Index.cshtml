@model IEnumerable<ElectroWarehouse.Models.Part>

@{
    ViewData["Title"] = "Электродетали";
}

<h1>Электродетали</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить электродеталь</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Наименование детали</th>
            <th>Артикул</th>
            <th>Количество на складе</th>
            <th>Поставщик</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Name)</td>
            <td>@Html.DisplayFor(modelItem => item.Article)</td>
            <td>@Html.DisplayFor(modelItem => item.QuantityInStock)</td>
            <td>@Html.DisplayFor(modelItem => item.Supplier.Name)</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Изменить</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Подробнее</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
            </td>
        </tr>
}
    </tbody>
</table>