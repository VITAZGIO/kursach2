@model IEnumerable<ElectroWarehouse.Models.Part>

@{
    ViewData["Title"] = "Электродетали";
}

<h1>Электродетали</h1>

<form asp-action="Index" method="get" class="row mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control"
               placeholder="Поиск по названию, артикулу или поставщику" />
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-primary">Найти</button>
        <a asp-action="Index" class="btn btn-secondary">Сбросить</a>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-success">Добавить электродеталь</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>
                <a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.NameSort">
                    Наименование детали @ViewBag.NameIcon
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.ArticleSort">
                    Артикул @ViewBag.ArticleIcon
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.QuantitySort">
                    Количество на складе @ViewBag.QuantityIcon
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.SupplierSort">
                    Поставщик @ViewBag.SupplierIcon
                </a>
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Name</td>
            <td>@item.Article</td>
            <td>@item.QuantityInStock</td>
            <td>@item.Supplier?.Name</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Подробнее</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
            </td>
        </tr>
}
    </tbody>
</table>