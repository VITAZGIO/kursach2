@model IEnumerable<ElectroWarehouse.Models.Supplier>

@{
    var isAdmin = ViewBag.IsAdmin == true;
    ViewData["Title"] = "Поставщики";
}

<h1>Поставщики</h1>

<form asp-action="Index" method="get" class="row mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control"
               placeholder="Поиск по названию или контактной информации" />
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-primary">Найти</button>
        <a asp-action="Index" class="btn btn-secondary">Сбросить</a>
    </div>
</form>

<p>
    @if (isAdmin)
    {
    <a asp-action="Create" class="btn btn-success">Добавить поставщика</a>
    }
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewBag.NameSort" asp-route-search="@ViewBag.Search">
                    Название поставщика @ViewBag.NameIcon
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewBag.ContactSort" asp-route-search="@ViewBag.Search">
                    Контактная информация @ViewBag.ContactIcon
                </a>
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Name</td>
            <td>@item.ContactInfo</td>
            <td>
                @if (isAdmin)
                {
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
                }
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Подробнее</a>
                @if (isAdmin)
                {
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>