@model IEnumerable<ElectroWarehouse.Models.WarehouseOperation>

@{
    var isAdmin = ViewBag.IsAdmin == true;
    ViewData["Title"] = "Складские операции";
}

<h1>Складские операции</h1>

<form asp-action="Index" method="get" class="row mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control"
               placeholder="Поиск по типу операции, сотруднику, детали или контроллеру" />
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-primary">Найти</button>
        <a asp-action="Index" class="btn btn-secondary">Сбросить</a>
    </div>
</form>

<p>
    @if (isAdmin)
    {
    <a asp-action="Create" class="btn btn-success">Добавить операцию</a>
    }
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewBag.TypeSort" asp-route-search="@ViewBag.Search">
                    Тип операции @ViewBag.TypeIcon
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewBag.DateSort" asp-route-search="@ViewBag.Search">
                    Дата операции @ViewBag.DateIcon
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewBag.QuantitySort" asp-route-search="@ViewBag.Search">
                    Количество @ViewBag.QuantityIcon
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewBag.EmployeeSort" asp-route-search="@ViewBag.Search">
                    Сотрудник @ViewBag.EmployeeIcon
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewBag.PartSort" asp-route-search="@ViewBag.Search">
                    Электродеталь @ViewBag.PartIcon
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewBag.ControllerSort" asp-route-search="@ViewBag.Search">
                    Контроллер @ViewBag.ControllerIcon
                </a>
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.OperationType</td>
            <td>@item.OperationDate.ToString("dd.MM.yyyy")</td>
            <td>@item.Quantity</td>
            <td>@($"{item.Employee?.LastName} {item.Employee?.FirstName}")</td>
            <td>@(item.Part?.Name ?? "—")</td>
            <td>@(item.ControllerDevice?.Name ?? "—")</td>
            <td>
                @if (isAdmin)
                {
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
                }
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Подробнее</a>
                @if (isAdmin)
                {
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>