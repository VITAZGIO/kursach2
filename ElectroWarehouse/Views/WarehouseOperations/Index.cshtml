@model IEnumerable<ElectroWarehouse.Models.WarehouseOperation>

@{
    ViewData["Title"] = "Складские операции";
}

<h1>Складские операции</h1>

<form asp-action="Index" method="get" class="row mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control"
               placeholder="Поиск по типу операции, сотруднику, детали или контроллеру" />
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-primary">Найти</button>
        <a asp-action="Index" class="btn btn-secondary">Сбросить</a>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить операцию</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Тип операции</th>
            <th>Дата операции</th>
            <th>Количество</th>
            <th>Сотрудник</th>
            <th>Электродеталь</th>
            <th>Контроллер</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@Html.DisplayFor(modelItem => item.OperationType)</td>
            <td>@Html.DisplayFor(modelItem => item.OperationDate)</td>
            <td>@Html.DisplayFor(modelItem => item.Quantity)</td>
            <td>@($"{item.Employee?.LastName} {item.Employee?.FirstName}")</td>
            <td>@(item.Part?.Name ?? "—")</td>
            <td>@(item.ControllerDevice?.Name ?? "—")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Изменить</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Подробнее</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
            </td>
        </tr>
}
    </tbody>
</table>