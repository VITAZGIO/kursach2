@model IEnumerable<ElectroWarehouse.Models.ControllerDevice>

@{
    ViewData["Title"] = "Контроллеры";
}

<h1>Контроллеры</h1>

<form asp-action="Index" method="get" class="row mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control"
               placeholder="Поиск по названию или степени защиты" />
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-primary">Найти</button>
        <a asp-action="Index" class="btn btn-secondary">Сбросить</a>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить контроллер</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>
                <a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.NameSort">
                    Наименование контроллера
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.PriceSort">
                    Цена
                </a>
            </th>
            <th>Степень защиты IP</th>
            <th>
                <a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.QuantitySort">
                    Количество на складе
                </a>
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Name)</td>
            <td>@Html.DisplayFor(modelItem => item.Price)</td>
            <td>@Html.DisplayFor(modelItem => item.IpRating)</td>
            <td>@Html.DisplayFor(modelItem => item.QuantityInStock)</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Изменить</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Подробнее</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
            </td>
        </tr>
}
    </tbody>
</table>